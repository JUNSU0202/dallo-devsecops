# ===================================
# Dallo DevSecOps 환경 변수 설정
# ===================================
# cp .env.example .env 후 값 설정

# --- LLM API ---
# 메인 프로바이더 (현재: gemini, 향후 확장: openai, anthropic)
LLM_PRIMARY_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
# OPENAI_API_KEY=sk-xxxx       # 비활성 (agent/providers/에 보존)
# ANTHROPIC_API_KEY=sk-ant-xxxx # 비활성 (agent/providers/에 보존)

# --- GitHub ---
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPOSITORY=owner/dallo-devsecops

# --- Database ---
# 로컬 개발: 비워두면 SQLite 자동 사용
# Docker:    postgresql://dallo:dallo_password@localhost:5432/dallo_db
DATABASE_URL=

# --- SonarQube ---
SONAR_HOST_URL=http://localhost:9000
SONAR_TOKEN=sqp_xxxxxxxxxxxxxxxxxxxx
SONAR_PROJECT_KEY=dallo-devsecops

# --- 보안 ---
# DB 코드 스니펫 AES-256 암호화 키 (필수 — 미설정 시 앱 시작 불가)
# 키 생성: python scripts/generate_encryption_key.py
DALLO_ENCRYPTION_KEY=<generate with: python scripts/generate_encryption_key.py>

# --- Celery + Redis ---
# Redis 미실행 시 자동으로 메모리 방식 fallback
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# API 인증 키 (콤마 구분으로 다중 키 지원)
# 미설정 시 인증 없이 접근 가능 (개발 환경 전용, 경고 출력)
DALLO_API_KEYS=dev-key-change-me
